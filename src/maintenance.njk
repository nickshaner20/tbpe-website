<section><div class="wrap" style="max-width:760px">
  <div class="note-box" style="border-left-color:var(--coral);margin-bottom:1.4rem"><b>🚨 Emergency?</b> Flooding, no heat/AC, gas smell, electrical hazard, or anything threatening safety — call <a href="tel:{{ site.phoneRaw }}"><b>{{ site.phone }}</b></a> immediately rather than using this form.</div>
  <div class="form-card">
    <h2 style="font-size:1.5rem;margin-bottom:1.2rem">Submit a non-emergency request</h2>
    <form onsubmit="this.style.display='none';document.getElementById('mok').style.display='block';return false">
      <div class="frow"><div class="field"><label>Your name</label><input required></div><div class="field"><label>Phone</label><input type="tel" required></div></div>
      <div class="frow one"><div class="field"><label>Property address / unit</label><input required></div></div>
      <div class="frow"><div class="field"><label>Issue type</label><select><option>Plumbing</option><option>Electrical</option><option>HVAC / AC</option><option>Appliance</option><option>Pest</option><option>Other</option></select></div><div class="field"><label>Best time to access</label><input placeholder="Weekday mornings"></div></div>
      <div class="frow one"><div class="field"><label>Describe the issue</label><textarea rows="4" required placeholder="What's happening, when it started, etc."></textarea></div></div>
      <div class="frow one"><div class="field"><label>Permission to enter if you're not home?</label><select><option>Yes, you may enter</option><option>No, contact me first</option></select></div></div>
      <button class="btn btn-primary btn-lg" type="submit" style="width:100%;justify-content:center">Submit Request</button>
